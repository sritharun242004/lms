# ============================================================
# Mentor Connect CMS — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.

# ── Database ─────────────────────────────────────────────────
# Point at any Postgres reachable from the running process.
DATABASE_URL="postgresql://<user>:<password>@<host>:5432/mentor_connect_cms?schema=public"

# ── JWT Secrets ──────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ── Next.js ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"

# ── Socket.IO Server ────────────────────────────────────────
SOCKET_PORT=4000
CLIENT_URL="http://localhost:3000"
SOCKET_INTERNAL_URL="http://localhost:4000"
INTERNAL_SECRET="dev-internal-secret-change-in-production"

# ── Cloudinary ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Email (Stub for now) ────────────────────────────────────
EMAIL_FROM="noreply@mentorconnect.dev"
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASS=""

# ── Redis (Optional - for Socket.IO scaling) ────────────────
# REDIS_URL="redis://localhost:6379"

# ── Admin Seed ───────────────────────────────────────────────
# Only read by `npm run db:seed`. Set a real password before seeding
# and never leave the default in a running environment.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="<set-a-real-password-before-seeding>"
ADMIN_NAME="Admin"
