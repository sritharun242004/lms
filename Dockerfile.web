# Simple, reliable Next.js runtime for the LMS.
# One-stage build: install everything, generate Prisma, build, then run next start.
FROM node:20-alpine
WORKDIR /app

COPY package.json package-lock.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/

RUN npm ci --workspaces --include-workspace-root

COPY apps/web ./apps/web
COPY packages/shared ./packages/shared

RUN cd apps/web && npx prisma generate && npm run build

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
EXPOSE 3000

WORKDIR /app/apps/web
CMD ["sh", "-c", "echo BOOT_START; ls -1 /app/apps/web/node_modules 2>/dev/null | head -3; ls -1 /app/node_modules/.bin/next 2>&1; exec npx --no-install next start"]
