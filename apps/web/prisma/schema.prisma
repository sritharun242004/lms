// ============================================================================
// Mentor Connect CMS — Prisma Schema
// PostgreSQL · Prisma v6 · Fully Normalized
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Enums
// ============================================================================

enum UserRole {
  ADMIN
  MENTOR
  MENTEE
}

enum UserStatus {
  ONLINE
  OFFLINE
  AWAY
}

enum MemberRole {
  OWNER
  MENTOR
  MENTEE
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  ANNOUNCEMENT
  POLL
  OPEN_QUESTION
  WORD_CLOUD
}

enum PollChartType {
  BAR
  DONUT
  PIE
}

// ============================================================================
// 1. User
// ============================================================================

model User {
  id                 String     @id @default(cuid())
  name               String
  // Guest mentees (joined via name + invite code, no account) have no
  // email or password — only mentors/admins and legacy full mentee
  // signups do. Postgres allows multiple NULLs in a unique column, so
  // any number of guest mentees can coexist.
  email              String?    @unique
  phone              String?    @unique
  password           String?
  role               UserRole   @default(MENTEE)
  bio                String?
  avatarUrl          String?    @map("avatar_url")
  status             UserStatus @default(OFFLINE)
  lastSeenAt         DateTime?  @map("last_seen_at")
  emailVerified      Boolean    @default(false) @map("email_verified")
  emailVerifyToken   String?    @map("email_verify_token")
  passwordResetToken String?    @map("password_reset_token")
  passwordResetExpiry DateTime? @map("password_reset_expiry")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  // Relations
  groups             GroupMember[]
  sentMessages       Message[]        @relation("MessageSender")
  deletedMessages    Message[]        @relation("MessageDeleter")
  refreshTokens      RefreshToken[]
  sessions           Session[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  createdGroups      Group[]
  createdInviteCodes InviteCode[]
  messageEdits       MessageHistory[]
  pollVotes          PollVote[]
  openAnswers        OpenAnswer[]
  wordCloudSubmissions WordCloudSubmission[]

  @@map("users")
}

// ============================================================================
// 2. RefreshToken
// ============================================================================

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================================================
// 3. Session
// ============================================================================

model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  userAgent    String?  @map("user_agent")
  ipAddress    String?  @map("ip_address")
  isActive     Boolean  @default(true) @map("is_active")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("sessions")
}

// ============================================================================
// 4. Group
// ============================================================================

model Group {
  id           String   @id @default(cuid())
  name         String
  description  String?
  wallpaperUrl String?  @map("wallpaper_url")
  createdById  String   @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  createdBy   User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  members     GroupMember[]
  messages    Message[]
  inviteCodes InviteCode[]

  @@index([createdById])
  @@map("groups")
}

// ============================================================================
// 5. GroupMember
// ============================================================================

model GroupMember {
  id       String     @id @default(cuid())
  userId   String     @map("user_id")
  groupId  String     @map("group_id")
  role     MemberRole @default(MENTEE)
  joinedAt DateTime   @default(now()) @map("joined_at")

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
  @@map("group_members")
}

// ============================================================================
// 6. Message
// ============================================================================

/// Full-text search: CREATE INDEX messages_content_search_idx ON messages USING GIN (to_tsvector('english', content));
model Message {
  id             String      @id @default(cuid())
  content        String
  type           MessageType @default(TEXT)
  groupId        String      @map("group_id")
  senderId       String      @map("sender_id")
  attachmentUrl  String?     @map("attachment_url")
  attachmentName String?     @map("attachment_name")
  isPinned       Boolean     @default(false) @map("is_pinned")
  isEdited       Boolean     @default(false) @map("is_edited")
  isDeleted      Boolean     @default(false) @map("is_deleted")
  deletedAt      DateTime?   @map("deleted_at")
  deletedById    String?     @map("deleted_by_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  // Relations
  group       Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender      User             @relation("MessageSender", fields: [senderId], references: [id], onDelete: Restrict)
  deletedBy   User?            @relation("MessageDeleter", fields: [deletedById], references: [id], onDelete: SetNull)
  editHistory  MessageHistory[]
  poll         Poll?
  openQuestion OpenQuestion?
  wordCloud    WordCloud?
  attachment   MessageAttachment?

  @@index([groupId, createdAt])
  @@index([senderId])
  @@index([deletedById])
  @@index([isPinned])
  @@index([type])
  @@map("messages")
}

// ============================================================================
// 6a. MessageAttachment
// ============================================================================

// Uploaded file bytes for a FILE-type message, stored in Postgres so no
// external object storage is required. `data` is kept out of every normal
// message list query (messageSelect only pulls mimeType/size) — it's read
// only when the download route streams this single row back.
model MessageAttachment {
  id        String   @id @default(cuid())
  messageId String   @unique @map("message_id")
  fileName  String   @map("file_name")
  mimeType  String   @map("mime_type")
  size      Int
  data      Bytes
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("message_attachments")
}

// ============================================================================
// 7. MessageHistory
// ============================================================================

model MessageHistory {
  id              String   @id @default(cuid())
  messageId       String   @map("message_id")
  previousContent String   @map("previous_content")
  editedById      String   @map("edited_by_id")
  version         Int
  editedAt        DateTime @default(now()) @map("edited_at")

  // Relations
  message  Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  editedBy User    @relation(fields: [editedById], references: [id], onDelete: Restrict)

  @@index([messageId])
  @@index([editedById])
  @@map("message_history")
}

// ============================================================================
// 7b. Poll — a live, votable multiple-choice message (Mentimeter-style)
// ============================================================================

model Poll {
  id            String        @id @default(cuid())
  messageId     String        @unique @map("message_id")
  question      String
  chartType     PollChartType @default(BAR) @map("chart_type")
  allowMultiple Boolean       @default(false) @map("allow_multiple")
  isClosed      Boolean       @default(false) @map("is_closed")
  createdAt     DateTime      @default(now()) @map("created_at")

  // Relations
  // No separate createdById — the linked message's sender is the poll's
  // creator (same ownership check already used for editing/deleting a
  // regular message covers polls too, since a poll is just a message).
  message Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]

  @@map("polls")
}

model PollOption {
  id     String @id @default(cuid())
  pollId String @map("poll_id")
  text   String
  order  Int

  // Relations
  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String   @map("poll_id")
  optionId  String   @map("option_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Unique per (option, user) rather than (poll, user) — this is what
  // lets `allowMultiple` polls record one row per option a user picks.
  // Single-choice polls enforce "one active vote" at the application
  // layer instead: casting a new vote deletes the user's other rows
  // for that poll first.
  @@unique([optionId, userId])
  @@index([pollId])
  @@index([userId])
  @@map("poll_votes")
}

// ============================================================================
// 7c. OpenQuestion — a free-text prompt where answers stack up live as a
// wall of anonymous cards (Mentimeter "Open Ended" style), rather than
// a bar/pie of counted options.
// ============================================================================

model OpenQuestion {
  id        String   @id @default(cuid())
  messageId String   @unique @map("message_id")
  question  String
  isClosed  Boolean  @default(false) @map("is_closed")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations — same "no createdById" reasoning as Poll: the linked
  // message's sender is the question's creator.
  message Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  answers OpenAnswer[]

  @@map("open_questions")
}

model OpenAnswer {
  id             String   @id @default(cuid())
  openQuestionId String   @map("open_question_id")
  userId         String   @map("user_id")
  text           String
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  openQuestion OpenQuestion @relation(fields: [openQuestionId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One answer per user per question — resubmitting updates this row
  // (its position in the wall stays put, ordered by original createdAt)
  // rather than adding a duplicate card.
  @@unique([openQuestionId, userId])
  @@index([openQuestionId])
  @@map("open_answers")
}

// ============================================================================
// 7d. WordCloud — a live-aggregated word cloud (Mentimeter-style). Every
// submission is normalized and merged into a per-word frequency count
// rather than displayed as a separate item, so the cloud never shows
// duplicate words.
// ============================================================================

model WordCloud {
  id                       String   @id @default(cuid())
  messageId                String   @unique @map("message_id")
  question                 String
  maxWordsPerParticipant   Int      @default(1) @map("max_words_per_participant")
  maxWordLength            Int      @default(200) @map("max_word_length")
  allowMultipleSubmissions Boolean  @default(false) @map("allow_multiple_submissions")
  profanityFilter          Boolean  @default(true) @map("profanity_filter")
  isLocked                 Boolean  @default(false) @map("is_locked")
  createdAt                DateTime @default(now()) @map("created_at")

  // Relations — same "no createdById" reasoning as Poll/OpenQuestion.
  message     Message               @relation(fields: [messageId], references: [id], onDelete: Cascade)
  entries     WordCloudEntry[]
  submissions WordCloudSubmission[]

  @@map("word_clouds")
}

model WordCloudEntry {
  id          String   @id @default(cuid())
  wordCloudId String   @map("word_cloud_id")
  // Normalized (trimmed, lowercased, punctuation-stripped) form — this
  // is what duplicate detection matches against.
  text        String
  count       Int      @default(1)
  // Assigned once, at first submission, and never recomputed — a word's
  // color must stay fixed for the life of the cloud.
  color       String
  firstSeenAt DateTime @default(now()) @map("first_seen_at")

  // Relations
  wordCloud   WordCloud             @relation(fields: [wordCloudId], references: [id], onDelete: Cascade)
  submissions WordCloudSubmission[]

  @@unique([wordCloudId, text])
  @@index([wordCloudId])
  @@map("word_cloud_entries")
}

model WordCloudSubmission {
  id          String   @id @default(cuid())
  wordCloudId String   @map("word_cloud_id")
  entryId     String   @map("entry_id")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  wordCloud WordCloud      @relation(fields: [wordCloudId], references: [id], onDelete: Cascade)
  entry     WordCloudEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([wordCloudId])
  @@index([userId])
  @@index([entryId])
  @@map("word_cloud_submissions")
}

// ============================================================================
// 8. InviteCode
// ============================================================================

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  groupId     String    @map("group_id")
  isActive    Boolean   @default(true) @map("is_active")
  usageCount  Int       @default(0) @map("usage_count")
  maxUsage    Int?      @map("max_usage")
  expiresAt   DateTime? @map("expires_at")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User  @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([groupId])
  @@index([createdById])
  @@index([isActive])
  @@index([expiresAt])
  @@map("invite_codes")
}

// ============================================================================
// 9. Notification
// ============================================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([type])
  @@map("notifications")
}

// ============================================================================
// 10. AuditLog
// ============================================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
